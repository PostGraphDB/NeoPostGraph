SET neopostgraph.show_dictionary_nulls = true;
SELECT vertex_set_dictionary(vertex_build(1, 21, 1, 0::smallint, '{"name": "Alice", "age": 30}'::gtype), 1);
                     vertex_set_dictionary                      
----------------------------------------------------------------
 {"id": 1, "label": "", "properties": {age: 30, name: "Alice"}}
(1 row)

