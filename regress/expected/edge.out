LOAD 'neopostgraph';
SET search_path TO  public, pg_catalog, NeoPostGraph;
SELECT FROM edge_in('{"name": "Alice", "age": 30}');
--
(1 row)

SELECT edge_in('{"name": "Alice", "age": 30}');
                                                     edge_in                                                     
-----------------------------------------------------------------------------------------------------------------
 {"id": 0, "start_vertex": (0,0), "edge_vertex": (0,0), "label": "", "properties": {"age": 30, "name": "Alice"}}
(1 row)

SELECT * FROM edge_in('{"name": "Alice", "age": 30}');
                                                     edge_in                                                     
-----------------------------------------------------------------------------------------------------------------
 {"id": 0, "start_vertex": (0,0), "edge_vertex": (0,0), "label": "", "properties": {"age": 30, "name": "Alice"}}
(1 row)

